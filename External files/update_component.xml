
<xg>
    <panel_widget height="420" id="comp" left="0" top="0" width="700">
        <bg_color>0xFF212121</bg_color>
        <corner_radius>8</corner_radius>
        <disabled_color>0x00000000</disabled_color>
        <image_widget height="49" id="icon" left="16" top="23" width="59">
            <anchor_pos left="16"/>
            <image>19</image>
            <scale_mode>keep_aspect</scale_mode>
            <index>6</index>
        </image_widget>
        <text_widget height="28" id="name" left="80" top="20" width="214">
            <text>
                <label>HX Stomp Firmware</label>
                <font name="Verdana" size="16"/>
                <align vert="middle"/>
                <text_color>0xFFEBEBEB</text_color>
            </text>
        </text_widget>
        <text_widget height="28" id="vers" left="305" top="20" width="110">
            <relative_pos x="50"/>
            <text>
                <label>3.01</label>
                <font name="Verdana" size="16" style="bold"/>
                <align horz="center" vert="middle"/>
                <text_color>0xFFEBEBEB</text_color>
            </text>
        </text_widget>
        <text_widget height="28" id="date" left="80" top="47" width="160">
            <text>
                <label>December 6, 2020</label>
                <font name="Verdana" size="12"/>
                <align vert="middle"/>
                <text_color>0xFFA9A9A9</text_color>
            </text>
        </text_widget>
        <pushbutton_widget height="25" id="upda" left="490" top="22" width="102">
            <anchor_pos right="16"/>
            <bg_color>0xFF004000</bg_color>
            <corner_radius>4</corner_radius>
            <text>
                <label>Update Now</label>
                <font name="Verdana" size="12" style="bold"/>
                <text_color>0xFFD6D6D6</text_color>
            </text>
            <active_state>
                <bg_color>0xFF797979</bg_color>
                <fg_color>0xFFFFFFFF</fg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF5E5E5E</bg_color>
                <fg_color>0xFFEBEBEB</fg_color>
            </hilite_state>
        </pushbutton_widget>
        <text_widget height="41" id="warn" left="16" top="76" width="668">
            <anchor_pos left="16" right="16"/>
            <text>
                <label>IMPORTANT: You must first update HX Edit to the latest version before updating your Helix firmware.</label>
                <font name="Verdana" size="13" style="bold"/>
                <align vert="middle"/>
                <multiline>yes</multiline>
                <text_color>0xFFFF2600</text_color>
            </text>
        </text_widget>
        <pushbutton_widget height="28" id="note" left="457" top="47" width="135">
            <anchor_pos right="16"/>
            <text>
                <label>Release Notes...</label>
                <font name="Verdana" size="12"/>
                <align horz="right"/>
                <text_color>0xFF0096FF</text_color>
            </text>
            <active_state>
                <fg_color>0xFF0096FF</fg_color>
            </active_state>
            <hilite_state>
                <fg_color>0xFF00C0FF</fg_color>
            </hilite_state>
        </pushbutton_widget>
        <panel_widget height="264" id="html" left="16" top="140" width="668">
            <anchor_pos bottom="16" left="16" right="16" top="140"/>
            <visible>no</visible>
            <bg_color>0xFF424242</bg_color>
        </panel_widget>
        <text_widget height="24" id="dlte" left="16" top="76" width="588">
            <anchor_pos left="16" right="96"/>
            <text>
                <label>Downloading...</label>
                <font name="Verdana" size="12"/>
                <align vert="middle"/>
                <text_color>0xFFA9A9A9</text_color>
            </text>
        </text_widget>
        <statusbar_widget height="12" id="dlpr" left="16" top="104" width="588">
            <anchor_pos left="16" right="96"/>
            <bg_color>0xFF424242</bg_color>
            <fill_area height="12" left="0" top="0" width="620"/>
            <fill_color>0xFF941100</fill_color>
        </statusbar_widget>
        <pushbutton_widget height="20" id="dlca" left="624" top="99" width="60">
            <anchor_pos right="16"/>
            <bg_color>0xFF424242</bg_color>
            <corner_radius>4</corner_radius>
            <text>
                <label>Cancel</label>
                <font name="Verdana" size="10"/>
                <text_color>0xFFD6D6D6</text_color>
            </text>
            <active_state>
                <bg_color>0xFF797979</bg_color>
                <fg_color>0xFFFFFFFF</fg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF5E5E5E</bg_color>
                <fg_color>0xFFEBEBEB</fg_color>
            </hilite_state>
        </pushbutton_widget>
    </panel_widget>
</xg>