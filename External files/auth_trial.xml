<xg>
	<panel_widget height="220" id="1" left="0" top="0" width="420">
		<anchor_pos bottom="0" top="0"/>
		<relative_pos x="50"/>
		
		<!-- Trial/Purchase message -->
		<text_widget height="100" id="msg-">
			<anchor_pos left="10" right="0" top="0"/>
			<text>
				<font name="Roboto Light" size="16"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFFB3B3B3</text_color>
				<multiline>yes</multiline>
			</text>
		</text_widget>

		<!-- Buy btn -->
		<pushbutton_widget height="29" id="buy-" left="0" top="120" width="250">
			<relative_pos x="50"/>
			<bg_color>0xFF000000</bg_color>
			<focus_color>0x00FF0000</focus_color>
			<border_color>0xFF336D87</border_color>
			<text>
				<label>Buy Helix Native</label>
				<font name="Roboto" size="14"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFFB3B3B3</text_color>
			</text>
			<button_repeat>no</button_repeat>
			<active_state>
				<bg_color>0xFF081D24</bg_color>
				<fg_color>0xFF3E84A3</fg_color>
			</active_state>
			<hilite_state>
				<bg_color>0xFF122F3A</bg_color>
			</hilite_state>
		</pushbutton_widget>

		<!-- Start Trial btn -->
		<pushbutton_widget height="29" id="try-" left="0" top="160" width="250">
			<relative_pos x="50"/>
			<bg_color>0xFF000000</bg_color>
			<focus_color>0x00FF0000</focus_color>
			<border_color>0xFF336D87</border_color>
			<text>
				<label>Start Free Trial</label>
				<font name="Roboto" size="14"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFFB3B3B3</text_color>
			</text>
			<button_repeat>no</button_repeat>
			<active_state>
				<bg_color>0xFF081D24</bg_color>
				<fg_color>0xFF3E84A3</fg_color>
			</active_state>
			<hilite_state>
				<bg_color>0xFF122F3A</bg_color>
			</hilite_state>
		</pushbutton_widget>

		<!-- Check purchase btn -->
		<pushbutton_widget height="50" id="chek" top="200" width="220">
			<anchor_pos left="10" right="10"/>
			<bg_color>0x00000000</bg_color>
			<focus_color>0x00000000</focus_color>
			<border_color>0x00000000</border_color>
			<text>
				<label>If you have already purchased Helix Native, click here to validate your purchase with the Line 6 Store</label>
				<font name="Roboto" size="14"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFF336D87</text_color>
				<multiline>yes</multiline>
			</text>
			<button_repeat>no</button_repeat>
			<active_state>
				<bg_color>0x00000000</bg_color>
				<fg_color>0x88336D87</fg_color>
			</active_state>
			<hilite_state>
				<fg_color>0xFF3E84A3</fg_color>
			</hilite_state>
		</pushbutton_widget>

	</panel_widget>
</xg>
