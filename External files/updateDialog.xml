<xg>
	<panel_widget height="180" id="1" left="0" top="0" width="440">
		<bg_color>0xFF393939</bg_color>

		<!-- Title -->
		<text_widget height="30" id="uddt">
			<anchor_pos left="10" right="10" top="5"/>
			<text>
                <label>Firmware Update Available!</label>
				<font name="Roboto" size="18"/>
				<align horz="center" vert="center"/>
				<text_color>0xFFB3B3B3</text_color>
				<multiline>no</multiline>
			</text>
		</text_widget>

		<!-- Message -->
		<text_widget height="100" id="updd">
			<anchor_pos left="30" right="30" top="50"/>
			<text>
                <label>Firmware update available! Click OK to proceed with update.</label>
				<font name="Roboto" size="14"/>
				<align horz="center" vert="top"/>
				<text_color>0xFFB3B3B3</text_color>
				<multiline>yes</multiline>
			</text>
		</text_widget>

		<!-- OK Button -->
        <pushbutton_widget height="25" id="okay" left="0" top="0" width="120">
            <anchor_pos bottom="8" right="8"/>
            <bg_color>0xFF595B5C</bg_color>
            <corner_radius>3</corner_radius>
            <text>
                <label>Update Now</label>
                <font name="Roboto" size="12"/>
                <align horz="center" vert="middle"/>
                <text_color>0xFFEDEDED</text_color>
            </text>
            <button_repeat>no</button_repeat>
            <active_state>
                <bg_color>0xFF595B5C</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF696C6E</bg_color>
            </hilite_state>
        </pushbutton_widget>

		<!-- Remind Me Later Button -->
        <pushbutton_widget height="25" id="canc" left="0" top="0" width="120">
            <anchor_pos left="8" bottom="8"/>
            <bg_color>0xFF595B5C</bg_color>
            <corner_radius>3</corner_radius>
            <text>
                <label>Remind Me Later</label>
                <font name="Roboto" size="12"/>
                <align horz="center" vert="middle"/>
                <text_color>0xFFEDEDED</text_color>
            </text>
            <button_repeat>no</button_repeat>
            <active_state>
                <bg_color>0xFF595B5C</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF696C6E</bg_color>
            </hilite_state>
        </pushbutton_widget>

        <!-- Release Notes Button -->
        <pushbutton_widget height="25" id="rlsn" left="160" top="0" width="120">
            <anchor_pos bottom="8"/>
            <bg_color>0xFF595B5C</bg_color>
            <corner_radius>3</corner_radius>
            <text>
                <label>Release Notes...</label>
                <font name="Roboto" size="12"/>
                <align horz="center" vert="middle"/>
                <text_color>0xFFEDEDED</text_color>
            </text>
            <button_repeat>no</button_repeat>
            <active_state>
                <bg_color>0xFF595B5C</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF696C6E</bg_color>
            </hilite_state>
        </pushbutton_widget>

	</panel_widget>
</xg>
