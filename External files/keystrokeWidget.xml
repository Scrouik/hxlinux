
<xg>
	<panel_widget height="44" id="keyc" left="0" name="Keystroke Configuration" top="0" width="1">
		<anchor_pos left="0" right="0"/>
		<disabled_color>0x00000000</disabled_color>
		<text_widget height="18" id="name" left="0" name="Label" top="0" width="60">
			<anchor_pos left="23" top="0"/>
			<text>
				<label>Keystroke</label>
				<font name="Roboto" size="12"/>
				<align horz="left" vert="middle"/>
				<text_color>0xFF00E0B0</text_color>
			</text>
		</text_widget>
		<panel_widget height="1" id="cmod" left="0" name="Capture mode" top="0" width="1">
			<anchor_pos bottom="0" left="23" right="23" top="18"/>
			<visible>no</visible>
			<bg_color>0xFF006600</bg_color>
			<border_color>0xFF434343</border_color>
			<text_widget height="1" id="clab" left="0" top="0" width="1">
				<anchor_pos bottom="1" left="25" right="25" top="0"/>
				<text>
					<label>Type key on keyboard...</label>
					<font name="Roboto" size="12"/>
					<align horz="center" vert="middle"/>
					<text_color>0xFFCCCCCC</text_color>
				</text>
			</text_widget>
			<pushbutton_widget height="0" id="kcan" left="0" top="0" width="38">
				<anchor_pos bottom="5" right="4" top="5"/>
				<bg_color>0xFFA1A1A1</bg_color>
				<border_thickness>0</border_thickness>
				<corner_radius>3</corner_radius>
				<text>
					<label>Cancel</label>
					<font name="Roboto" size="10"/>
					<align horz="center" vert="middle"/>
				</text>
				<button_repeat>no</button_repeat>
				<active_state>
					<bg_color>0xFF828282</bg_color>
				</active_state>
				<hilite_state>
					<bg_color>0xFFC1C1C1</bg_color>
				</hilite_state>
			</pushbutton_widget>
		</panel_widget>
		<panel_widget height="1" id="nmod" left="0" name="Normal mode" top="0" width="1">
			<anchor_pos bottom="0" left="23" right="23" top="18"/>
			<visible>yes</visible>
			<border_color>0xFF434343</border_color>
			<pushbutton_widget height="1" id="capt" left="0" name="Capture Button" top="0" width="24">
				<anchor_pos bottom="1" right="0" top="1"/>
				<image>75</image>
				<button_repeat>no</button_repeat>
			</pushbutton_widget>
			<text_menu_widget height="1" id="kymn" left="0" name="Menu" top="0" width="110">
				<anchor_pos bottom="2" right="25" top="1"/>
				<chevron_pos>7</chevron_pos>
				<chevron_size>5</chevron_size>
				<text>
					<font name="Roboto" size="12"/>
					<align horz="right" vert="middle"/>
					<offset x="-4" y="0"/>
					<text_color>0xFFD0D0D0</text_color>
				</text>
				<menu>
					<item_height>16</item_height>
					<max_menu_height>9999</max_menu_height>
					<min_visible_items>5</min_visible_items>
					<right_margin>10</right_margin>
					<auto_hide_margins>no</auto_hide_margins>
					<font name="Roboto" size="11"/>
					<align horz="left"/>
					<text_color>0xFFD0D0D0</text_color>
					<bg_color>0xFF0C0C0C</bg_color>
					<border_color>0xFF000000</border_color>
					<hilite_bg_color>0xFF626262</hilite_bg_color>
					<vscroll>
						<width>8</width>
						<border_thickness>0</border_thickness>
						<bg_color>0xFF1A1A1A</bg_color>
						<arrow_buttons size="0"/>
						<thumb_color>0xFF808080</thumb_color>
						<thumb_hilite_color>0xFFCCCCCC</thumb_hilite_color>
					</vscroll>
				</menu>
				<arrow_buttons align="right">
					<chevron_size>4</chevron_size>
					<fg_color>0xFFD0D0D0</fg_color>
					<bg_color>0x00FFFFFF</bg_color>
					<border_color>0xFFB3B3B3</border_color>
					<border_thickness>0</border_thickness>
					<button_repeat>yes</button_repeat>
				</arrow_buttons>
			</text_menu_widget>
			<image_widget height="0" id="mod1" left="4" name="Mod 1 Image" top="0" width="0">
				<relative_pos y="50"/>
				<image>73</image>
			</image_widget>
			<image_widget height="0" id="mod2" left="35" name="Mod 2 Image" top="0" width="0">
				<relative_pos y="50"/>
				<image>73</image>
			</image_widget>
			<image_widget height="0" id="mod3" left="66" name="Mod 2 Image" top="0" width="0">
				<relative_pos y="50"/>
				<image>73</image>
			</image_widget>
		</panel_widget>
	</panel_widget>
</xg>