
<xg>
    <panel_widget height="400" id="main" left="0" top="0" width="550">
        <bg_color>0xFF393939</bg_color>
        <text_widget height="17" id="1" left="10" name="Info label" top="10" width="1">
            <anchor_pos left="8" right="8" top="8"/>
            <bg_color>0x00000000</bg_color>
            <text>
                <label>Create a Helix Backup (.hxb) to store all your presets, IRs and Global Settings in a single file.</label>
                <font name="Roboto" size="11"/>
                <align horz="center" vert="middle"/>
                <text_color>0xFFBEBEBE</text_color>
            </text>
        </text_widget>
        <panel_widget height="1" id="view" left="0" top="0" width="1">
            <anchor_pos bottom="41" left="8" right="8" top="30"/>
            <bg_color>0xFF0C0C0C</bg_color>
            <corner_radius>5</corner_radius>
            <panel_widget height="160" id="info" left="0" top="15" width="1">
                <anchor_pos left="0" right="0"/>
                <bg_color>0xFF0C0C0C</bg_color>
                <corner_radius>5</corner_radius>
                <disabled_color>0x80000000</disabled_color>
                <text_widget height="25" id="1" left="0" name="Filename label" top="0" width="75">
                    <bg_color>0x00000000</bg_color>
                    <text>
                        <label>Name:</label>
                        <font name="Roboto" size="12"/>
                        <align horz="right" vert="middle"/>
                        <text_color>0xFF858585</text_color>
                    </text>
                </text_widget>
                <text_edit_widget height="25" id="file" left="0" name="Filename" top="0" width="1">
                    <anchor_pos left="85" right="85"/>
                    <bg_color>0xFF282828</bg_color>
                    <corner_radius>3</corner_radius>
                    <text>
                        <label>Text</label>
                        <font name="Roboto" size="12" weight="bold"/>
                        <text_color>0xFFE6E6E6</text_color>
                    </text>
                    <activate_on_focus>yes</activate_on_focus>
                </text_edit_widget>
                <text_widget height="25" id="1" left="0" name="Description Label" top="40" width="75">
                    <bg_color>0x00000000</bg_color>
                    <text>
                        <label>Description:</label>
                        <font name="Roboto" size="12"/>
                        <align horz="right" vert="middle"/>
                        <text_color>0xFF858585</text_color>
                    </text>
                </text_widget>
                <text_edit_widget height="65" id="desc" left="85" name="Description" top="40" width="364">
                    <anchor_pos left="85" right="85"/>
                    <bg_color>0xFF282828</bg_color>
                    <corner_radius>3</corner_radius>
                    <text>
                        <label>Text</label>
                        <font name="Roboto" size="12"/>
                        <align vert="top"/>
                        <multiline>yes</multiline>
                        <text_color>0xFFE6E6E6</text_color>
                    </text>
                    <activate_on_focus>yes</activate_on_focus>
                    <scrolling>
                        <enabled>yes</enabled>
                        <scrollbars>
                            <visibility h="none"/>
                            <width>8</width>
                            <border_color>0x00000000</border_color>
                            <bg_color>0xFF1A1A1A</bg_color>
                            <thumb_color>0xFF808080</thumb_color>
                            <thumb_hilite_color>0xFFCCCCCC</thumb_hilite_color>
                            <arrow_buttons size="0"/>
                        </scrollbars>
                    </scrolling>
                </text_edit_widget>
                <text_widget height="16" id="1" left="0" name="Folder Label" top="120" width="75">
                    <bg_color>0x00000000</bg_color>
                    <text>
                        <label>Where:</label>
                        <font name="Roboto" size="12"/>
                        <align horz="right" vert="middle"/>
                        <text_color>0xFF858585</text_color>
                    </text>
                </text_widget>
                <pushbutton_widget height="12" id="brws" left="85" name="Browse" top="122" width="16">
                    <bg_color>0x00000000</bg_color>
                    <image>59</image>
                    <icon_placement spacing="4">-1</icon_placement>
                    <text>
                        <font name="Helvetica" size="12"/>
                    </text>
                </pushbutton_widget>
                <text_widget height="16" id="fldr" left="0" name="Folder" top="120" width="1">
                    <anchor_pos left="108" right="85"/>
                    <bg_color>0x00000000</bg_color>
                    <text>
                        <label>Text Label</label>
                        <font name="Roboto" size="12"/>
                        <text_color>0xFFE6E6E6</text_color>
                    </text>
                </text_widget>
            </panel_widget>
            <text_widget height="17" id="stat" left="0" name="Status Label" top="190" width="1">
                <anchor_pos left="85" right="85"/>
                <visible>no</visible>
                <bg_color>0x00000000</bg_color>
                <text>
                    <label>Creating backup...</label>
                    <font name="Roboto" size="12"/>
                    <align horz="center" vert="middle"/>
                    <text_color>0xFFE6E6E6</text_color>
                </text>
            </text_widget>
            <tree_widget height="120" id="tree" left="0" top="180" width="1">
                <anchor_pos left="85" right="85"/>
                <visible>no</visible>
                <bg_color>0xFF282828</bg_color>
                <corner_radius>3</corner_radius>
                <text_color>0xFFE6E6E6</text_color>
                <hilite_color>0x00000000</hilite_color>
                <font name="Roboto" size="12"/>
                <item_height>22</item_height>
                <icon>0</icon>
                <allow_editing>no</allow_editing>
                <tree_item id="300">
                    <label>Global Settings</label>
                </tree_item>
                <tree_item id="200">
                    <label>Impulse Responses</label>
                </tree_item>
                <tree_item id="400">
                    <label>Favorites</label>
                </tree_item>
                <tree_item id="500">
                    <label>User Model Defaults</label>
                </tree_item>
                <tree_item id="100">
                    <label>Presets</label>
                </tree_item>
            </tree_widget>
        </panel_widget>
        <pushbutton_widget height="25" id="doit" left="0" name="Backup Button" top="0" width="120">
            <anchor_pos bottom="8" right="8"/>
            <bg_color>0xFF595B5C</bg_color>
            <corner_radius>3</corner_radius>
            <icon_placement spacing="4">-1</icon_placement>
            <text>
                <label>Create Backup</label>
                <font name="Roboto" size="12"/>
                <text_color>0xFFEDEDED</text_color>
            </text>
            <active_state>
                <bg_color>0xFF595B5C</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF696C6E</bg_color>
            </hilite_state>
        </pushbutton_widget>
        <pushbutton_widget height="25" id="canc" left="0" name="Close Button" top="0" width="80">
            <anchor_pos bottom="8" left="8"/>
            <bg_color>0xFF595B5C</bg_color>
            <corner_radius>3</corner_radius>
            <icon_placement spacing="4">-1</icon_placement>
            <text>
                <label>Cancel</label>
                <font name="Roboto" size="12"/>
                <text_color>0xFFEDEDED</text_color>
            </text>
            <active_state>
                <bg_color>0xFF595B5C</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF696C6E</bg_color>
            </hilite_state>
        </pushbutton_widget>
        <pushbutton_widget height="25" id="abrt" left="0" name="Abort Button" top="0" width="80">
            <anchor_pos bottom="8" left="8"/>
            <visible>no</visible>
            <bg_color>0xFF595B5C</bg_color>
            <corner_radius>3</corner_radius>
            <icon_placement spacing="4">-1</icon_placement>
            <text>
                <label>Cancel</label>
                <font name="Roboto" size="12"/>
                <text_color>0xFFEDEDED</text_color>
            </text>
            <active_state>
                <bg_color>0xFF595B5C</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF696C6E</bg_color>
            </hilite_state>
        </pushbutton_widget>
    </panel_widget>
</xg>