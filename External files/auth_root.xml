<xg>
	<panel_widget height="606" id="1" left="0" top="0" width="1034">
		<anchor_pos bottom="0" left="0" right="0" top="0"/>
		<bg_color>0xFF000000</bg_color>

		<!-- Polygon background -->
		<image_widget height="0" id="poly" left="0" name="Polygon Left" top="0" width="0">
			<anchor_pos bottom="0" right="0" left="0" top="0"/>
			<scale_mode>stretch</scale_mode>
			<image>24</image>
		</image_widget>

		<image_widget height="0" id="glow" left="0" name="Glow" top="0" width="1914">
			<anchor_pos bottom="0" top="0"/>
			<relative_pos x="50"/>
			<scale_mode>keep_aspect</scale_mode>
			<image>23</image>
		</image_widget>

		<!-- Close button -->
		<pushbutton_widget height="25" id="clos" left="0" top="0" width="50">
			<visible>no</visible>
			<anchor_pos bottom="8" right="8"/>
			<bg_color>0xFF595B5C</bg_color>
			<corner_radius>3</corner_radius>
			<text>
				<label>CLOSE</label>
				<font name="Roboto" size="12"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFFEDEDED</text_color>
			</text>
			<button_repeat>no</button_repeat>
			<active_state>
				<bg_color>0xFF595B5C</bg_color>
			</active_state>
			<hilite_state>
				<bg_color>0xFF696C6E</bg_color>
			</hilite_state>
		</pushbutton_widget>

		<!-- Centered layout container for static and dynamic content -->
		<panel_widget height="1" id="1" left="0" top="0" width="575">
			<anchor_pos bottom="0" top="0"/>
			<relative_pos x="50" y="0"/>
			<bg_color>0x00000000</bg_color>
			
			<!-- Account Login -->
			<text_widget height="20" id="vlog">
				<anchor_pos top="10" left="0" right="0"/>
				<relative_pos x="50"/>
				<text>
					<font name="Roboto Light" size="14"/>
					<align horz="center" vert="top"/>
					<text_color>0xFFA1A1A1</text_color>
				</text>
			</text_widget>

			<!-- Logout button -->
			<pushbutton_widget height="20" id="lgot" width="70">
				<anchor_pos top="30"/>
				<relative_pos x="50"/>
				<bg_color>0x00000000</bg_color>
				<focus_color>0x00000000</focus_color>
				<border_color>0x00000000</border_color>
				<visible>no</visible>
				<text>
					<label>Sign Out</label>
					<font name="Roboto" size="14"/>
					<align horz="center" vert="middle"/>
					<text_color>0xFF336D87</text_color>
				</text>
				<button_repeat>no</button_repeat>
				<active_state>
					<bg_color>0x00000000</bg_color>
					<fg_color>0x88336D87</fg_color>
				</active_state>
				<hilite_state>
					<fg_color>0xFF3E84A3</fg_color>
				</hilite_state>
			</pushbutton_widget>

			<panel_widget height="60" id="dbug" name="Status View" left="0" top="0" width="0">
				<anchor_pos bottom="20" left="0" right="0"/>

				<!-- Status labels -->
				<panel_widget height="75" left="0" top="0" width="0">
					<anchor_pos top="0" left="0"/>
					<relative_pos width="50"/>
					<bg_color>0x66000000</bg_color>
					<corner_radius>10</corner_radius>

					<!-- License status -->
					<text_widget height="20" id="slic">
						<anchor_pos left="10" right="0" top="0"/>
						<text>
							<label>License Status:</label>
							<font name="Roboto" size="12"/>
							<align horz="right" vert="top"/>
							<text_color>0xFFA1A1A1</text_color>
						</text>
					</text_widget>

					<!-- Auth status -->
					<text_widget height="20" id="sath">
						<anchor_pos left="10" right="0" top="15"/>
						<text>
							<label>Computer Authorization:</label>
							<font name="Roboto" size="12"/>
							<align horz="right" vert="top"/>
							<text_color>0xFFA1A1A1</text_color>
						</text>
					</text_widget>

					<!-- Server URL (for test only) -->
					<text_widget height="20" id="svr-">
						<anchor_pos left="10" right="0" top="30"/>
						<text>
							<label>License Server:</label>
							<font name="Roboto" size="12"/>
							<align horz="right" vert="top"/>
							<text_color>0xFFA1A1A1</text_color>
						</text>
					</text_widget>

				</panel_widget>

				<!-- Status values -->
				<panel_widget height="75" left="0" top="0" width="0">
					<anchor_pos top="0" right="0"/>
					<relative_pos width="50"/>
					<bg_color>0x66000000</bg_color>
					<corner_radius>10</corner_radius>

					<!-- License value -->
					<text_widget height="20" id="vlic">
						<anchor_pos left="10" right="0" top="0"/>
						<text>
							<label>UNCONFIRMED</label>
							<font name="Roboto" size="12"/>
							<align horz="left" vert="top"/>
							<text_color>0xFFA1A1A1</text_color>
						</text>
					</text_widget>

					<!-- Auth value -->
					<text_widget height="20" id="vath">
						<anchor_pos left="10" right="0" top="15"/>
						<text>
							<label>UNCONFIRMED</label>
							<font name="Roboto" size="12"/>
							<align horz="left" vert="top"/>
							<text_color>0xFFA1A1A1</text_color>
						</text>
					</text_widget>

					<!-- Server value -->
					<text_widget height="20" id="vsvr">
						<anchor_pos left="10" right="0" top="30"/>
						<text>
							<font name="Roboto" size="12"/>
							<align horz="left" vert="top"/>
							<text_color>0xFFA1A1A1</text_color>
						</text>
					</text_widget>

					<!-- De-auth button -->
					<pushbutton_widget height="20" id="daut" width="15">
						<anchor_pos right="100" top="40"/>
						<bg_color>0x00000000</bg_color>
						<focus_color>0x00000000</focus_color>
						<border_color>0x00000000</border_color>
						<visible>no</visible>
						<text>
							<label>Deauthorize</label>
							<font name="Roboto" size="12"/>
							<align horz="center" vert="middle"/>
							<text_color>0xFF336D87</text_color>
						</text>
						<button_repeat>no</button_repeat>
						<active_state>
							<bg_color>0x00000000</bg_color>
							<fg_color>0x88336D87</fg_color>
						</active_state>
						<hilite_state>
							<fg_color>0xFF3E84A3</fg_color>
						</hilite_state>
					</pushbutton_widget>

				</panel_widget>

			</panel_widget>

			<!-- Logo view -->
			<image_widget height="110" id="1" left="0" top="0" width="0">
				<anchor_pos top="60" right="0" left="10"/>
				<scale_mode>keep_aspect</scale_mode>
				<image>25</image>
			</image_widget>

			<!-- Status message -->
			<text_widget height="90" id="stat" name="Status Message">
				<anchor_pos left="10" right="0" top="180"/>
				<text>
					<font name="Roboto" size="24"/>
					<align horz="center" vert="top"/>
					<text_color>0xFFB3B3B3</text_color>
					<multiline>yes</multiline>
				</text>
			</text_widget>

			<!-- Activity spinner -->
			<image_widget height="25" id="dnax" left="0" name="DNA Animation" top="0" width="103">
				<anchor_pos top="250"/>
				<relative_pos x="50"/>
				<image>8</image>
			</image_widget>

			<!-- Child VC container -->
			<panel_widget height="0" id="chld" left="0" top="0" width="0">
				<anchor_pos left="10" right="10" top="250" bottom="10"/>
				<corner_radius>10</corner_radius>
				<bg_color>0x00000000</bg_color>
			</panel_widget>

		</panel_widget>
	</panel_widget>
</xg>
