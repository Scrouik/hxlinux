
<xg>
	<panel_widget height="606" id="main" left="0" name="Main View" top="0" width="1034">
		<anchor_pos bottom="0" left="0" top="0" right="0"/>
		<bg_color>0xFF1D1D1D</bg_color>
		<!-- Error Bar -->
		<panel_widget height="32" id="errb" left="0" name="Error Bar" top="0" width="1">
			<anchor_pos left="0" right="0" top="0"/>
			<visible>no</visible>
			<bg_color>0xFFFF8000</bg_color>
			<text_widget height="1" id="etxt" left="0" name="Error Text " top="0" width="1">
				<anchor_pos bottom="0" left="0" right="0" top="0"/>
				<text>
					<label></label>
					<font name="Roboto" size="14" style="bold"/>
					<align horz="left" vert="middle"/>
					<offset x="5" y="0"></offset>
					<multiline>yes</multiline>
				</text>
			</text_widget>
		</panel_widget>

		<!-- Statusbar view-->
		<panel_widget height="35" id="stbw" left="0" top="1" width="1">
			<anchor_pos bottom="0" left="0" right="0"/>
			<bg_color>0xFF1D1D1D</bg_color>

			<!-- Settings (preferences) button -->
			<pushbutton_widget width="19" height="19" id="sett" name="Settings Button">
				<anchor_pos left="8"/>
				<relative_pos y="50"/>
				<image>51</image>
			</pushbutton_widget>

			<!-- Help button -->
			<pushbutton_widget height="23" width="23" id="hlpb">
				<anchor_pos left="32"/>
				<relative_pos y="50"/>
				<image>53</image>
				<button_repeat>no</button_repeat>
			</pushbutton_widget>

			<!-- Help menu (hidden) -->
			<text_menu_widget height="1" id="hlpm" width="1" top="0" bottom="0">
				<visible>no</visible>
				<menu>
					<font name="Roboto" size="12"/>
					<text_color>0xFFD0D0D0</text_color>
					<bg_color>0xFF28282A</bg_color>
					<hilite_text_color>0xFFFFFFFF</hilite_text_color>
					<hilite_bg_color>0xFF474747</hilite_bg_color>
					<border_thickness>0</border_thickness>
					<menu_item id="1">
						<label>About</label>
					</menu_item>
					<menu_item id="3">
						<label>Online Help</label>
					</menu_item>
					<menu_item id="4">
						<label>Pilot's Guide</label>
					</menu_item>
				</menu>
			</text_menu_widget>

			<!-- vertical separator-->
			<panel_widget width="1" id="1" name="vertical separator">
				<anchor_pos left="60" bottom="5" top="5"/>
				<bg_color>0xFF4A4A4A</bg_color>
			</panel_widget>

			<!-- Login status dot indicator (HX Edit/Native) -->
			<panel_widget width="8" height="8" id="log-" name="Login indicator">
				<corner_radius>3</corner_radius>
				<relative_pos y="50"/>
				<anchor_pos left="67"/>
				<border_color>0xFFABABAB</border_color>
				<border_thickness>1</border_thickness>
			</panel_widget>

			<!-- Auth Name button/popup menu (HX Edit/Native) -->
			<pushbutton_widget width="100" id="aunb" name="Auth Name Button">
				<bg_color>0x00000000</bg_color>
				<anchor_pos left="82" top="8" bottom="10"/>
				<text>
                    <disabled_opacity>33</disabled_opacity>
					<label>My Account</label>
					<font name="Roboto" size="12"/>
					<align horz="left" vert="middle"/>
					<text_color>0xFFCCCCCC</text_color>
				</text>
				<hilite_state>
					<fg_color>0xFFFFFFFF</fg_color>
				</hilite_state>
				<active_state>
					<fg_color>0xFFCCCCCC</fg_color>
				</active_state>
				<visible>no</visible>
			</pushbutton_widget>

			<!-- Trial button -->
			<pushbutton_widget height="25" id="trlb" name="Trial Button" left="10" top="0" width="1">
				<bg_color>0x00000000</bg_color>
				<anchor_pos left="239"/>
				<relative_pos y="50"/>
				<text>
					<label>Authorize</label>
					<font name="Avenir Next Condensed" size="12"/>
					<align horz="left" vert="middle"/>
					<text_color>0xFF999999</text_color>
				</text>
				<active_state>
					<fg_color>0xFFD0D0D0</fg_color>
				</active_state>
				<hilite_state>
					<fg_color>0xFFD0D0D0</fg_color>
				</hilite_state>
			</pushbutton_widget>
            
            <!-- Update button -->
            <toggle_widget height="19" id="updt" name="Update Button" left="180" top="0" width="220">
                <visible>no</visible>
                <corner_radius>1</corner_radius>
                <anchor_pos right="10"/>
                <relative_pos y="50"/>
                <text>
                    <label>Check for Updates...</label>
                    <font name="Roboto" size="12"/>
                    <align horz="right" vert="middle"/>
                    <text_color>0xFFCCCCCC</text_color>
                </text>
            </toggle_widget>

			<!-- Device status -->
			<panel_widget height="1" id="devw" left="0" name="Device View" width="222">
				<anchor_pos top="0" bottom="0"/>
				<relative_pos x="50"/>
				<image_widget height="1" id="dvim" left="0" name="Device Image" top="1" width="64">
					<anchor_pos left="0" top="2" bottom="2"/>
					<image>9</image>
					<scale_mode>keep_aspect</scale_mode>
				</image_widget>
				<text_widget height="1" id="fwvr" left="1" top="1" width="150">
					<anchor_pos left="72" top="0" bottom="0"/>
					<relative_pos y="50"/>
					<text>
						<label>Helix Firmware 1.80.1a</label>
						<font name="Avenir Next Condensed Demi Bold" size="12"/>
						<align horz="left" vert="middle"/>
						<multiline>yes</multiline>
						<text_color>0xFFBBBBBB</text_color>
					</text>
				</text_widget>
				<image_widget height="1" id="anim" left="1" top="1" width="64">
					<anchor_pos left="5" top="0" bottom="0"/>
					<scale_mode>keep_aspect</scale_mode>
					<visible>no</visible>
					<image>7</image>
				</image_widget>
				<pushbutton_widget height="1" id="reco" left="0" top="1" width="64">
					<anchor_pos left="0" top="4" bottom="4"/>
					<bg_color>0xFF696C6E</bg_color>
					<corner_radius>3</corner_radius>
					<text>
						<label>Reconnect</label>
                        <font name="Avenir Next Condensed Demi Bold" size="12"/>
                        <align horz="center" vert="middle"/>
						<text_color>0xFFEDEDED</text_color>
					</text>
					<button_repeat>no</button_repeat>
					<active_state>
						<bg_color>0xFF595B5C</bg_color>
					</active_state>
					<hilite_state>
						<bg_color>0xFF696C6E</bg_color>
					</hilite_state>
				</pushbutton_widget>
			</panel_widget>

			<!-- MIDI In status dot indicator (Native) -->
			<panel_widget width="8" height="8" id="midi" name="MIDI In activity">
				<anchor_pos right="75"/>
				<visible>no</visible>
				<corner_radius>4</corner_radius>
				<relative_pos y="50"/>
				<border_color>0xFFABABAB</border_color>
				<border_thickness>1</border_thickness>
			</panel_widget>

			<!-- MIDI In status Label (Native) -->
            <text_widget height="1" id="midl" left="1" top="1" width="150">
                <anchor_pos right="88" top="0" bottom="0"/>
				<visible>no</visible>
                <relative_pos y="50"/>
                <text>
                    <label>MIDI In:</label>
                    <font name="Avenir Next Condensed Demi Bold" size="12"/>
                    <align horz="right" vert="middle"/>
                    <text_color>0xFFBBBBBB</text_color>
                </text>
            </text_widget>

			<!-- Sync'ing licenses indicator -->
			<image_widget height="32" id="sync" left="1" top="1" width="32">
				<anchor_pos right="10"/>
				<relative_pos y="50"/>
				<scale_mode>keep_aspect</scale_mode>
				<visible>no</visible>
				<image>67</image>
			</image_widget>
		</panel_widget>

		<panel_widget height="1" id="livw" left="10" name="Librarian View Placeholder" top="0" width="220">
			<anchor_pos bottom="35" left="8" top="8"/>
			<bg_color>0xFF004080</bg_color>
			<text_widget height="1" id="1" left="0" top="0" width="1">
				<anchor_pos bottom="0" left="0" right="0" top="0"/>
				<text>
					<label>(List View Placeholder)</label>
					<font name="Roboto" size="12"/>
					<align horz="center" vert="middle"/>
					<text_color>0xFFB3B3B3</text_color>
				</text>
			</text_widget>
		</panel_widget>
		<panel_widget height="1" id="edvw" left="0" name="Editor View Placeholder" top="0" width="1">
			<anchor_pos bottom="35" left="228" right="0" top="0"/>
			<bg_color>0xFF000080</bg_color>
			<text_widget height="1" id="1" left="0" top="0" width="1">
				<anchor_pos bottom="0" left="0" right="0" top="0"/>
				<text>
					<label>(Editor View Placeholder)</label>
					<font name="Roboto" size="12"/>
					<align horz="center" vert="middle"/>
					<text_color>0xFFB3B3B3</text_color>
				</text>
			</text_widget>
		</panel_widget>
	</panel_widget>
</xg>
