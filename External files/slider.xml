
<xg>
    <panel_widget height="30" id="slvw" left="0" name="Slider View" top="0" width="1">
        <anchor_pos left="0" right="0"/>
        <bg_color>0xFF0C0C0C</bg_color>
        <disabled_color>0x00000000</disabled_color>
        <image_widget height="9" id="auto" left="0" name="Auto Assign" top="0" width="21">
            <anchor_pos left="0" top="5"/>
            <bg_color>0x00000000</bg_color>
            <image>27</image>
        </image_widget>
        <image_widget height="9" id="ctrl" left="0" name="Ctrl Assign" top="0" width="19">
            <anchor_pos left="2" top="5"/>
            <bg_color>0x00000000</bg_color>
            <image>70</image>
        </image_widget>
        <image_widget height="20" id="mlrn" left="0" name="MIDI Learn" top="0" width="16">
            <anchor_pos left="2" top="5"/>
            <visible>no</visible>
            <bg_color>0x00000000</bg_color>
            <image>82</image>
            <scale_mode>keep_aspect</scale_mode>
        </image_widget>
        <slider_widget height="1" id="sldr" left="0" name="Slider" top="0" width="1">
            <anchor_pos bottom="0" left="23" right="23" top="0"/>
            <bg_color>0xFF1F1F1F</bg_color>
            <thumb_center x="6" y="15"/>
            <thumb_size height="30" width="12"/>
            <pixel_range x="6" y="15">84</pixel_range>
        </slider_widget>
        <text_widget height="18" id="name" left="0" name="Label" top="0" width="60">
            <anchor_pos left="23" top="0"/>
            <bg_color>0x00000000</bg_color>
            <text>
                <label>Text Label</label>
                <font name="Roboto" size="12"/>
                <align vert="middle"/>
                <text_color>0xFFD0D0D0</text_color>
            </text>
        </text_widget>
        <number_text_edit_widget height="18" id="edit" left="0" name="Edit" top="0" width="85">
            <anchor_pos right="23" top="0"/>
            <visible>no</visible>
            <bg_color>0x00000000</bg_color>
            <text>
                <label>0</label>
                <font name="Roboto" size="12"/>
                <align horz="right"/>
                <offset x="-5"/>
                <text_color>0xFFD0D0D0</text_color>
            </text>
            <arrow_buttons size="10">
                <chevron_size>4</chevron_size>
                <fg_color>0xFFD0D0D0</fg_color>
                <bg_color>0x00FFFFFF</bg_color>
                <border_thickness>0</border_thickness>
            </arrow_buttons>
        </number_text_edit_widget>
        <text_menu_widget height="18" id="menu" left="285" name="Menu" top="0" width="150">
            <anchor_pos right="23" top="0"/>
            <bg_color>0x00000000</bg_color>
            <chevron_pos>6</chevron_pos>
            <text>
                <label>Text Menu</label>
                <font name="Roboto" size="12"/>
                <align horz="right"/>
                <offset x="-4"/>
                <text_color>0xFFD0D0D0</text_color>
            </text>
            <menu>
                <item_height>24</item_height>
                <max_menu_height>9999</max_menu_height>
                <min_visible_items>5</min_visible_items>
                <right_margin>10</right_margin>
                <auto_hide_margins>no</auto_hide_margins>
                <font name="Roboto" size="12"/>
                <text_color>0xFFD0D0D0</text_color>
                <bg_color>0xFF0C0C0C</bg_color>
                <hilite_bg_color>0xFF626262</hilite_bg_color>
                <icon>0</icon>
                <scrolling>
                    <scrollbars>
                        <width>8</width>
                        <border_color>0x00000000</border_color>
                        <border_thickness>0</border_thickness>
                        <bg_color>0xFF1A1A1A</bg_color>
                        <thumb_color>0xFF808080</thumb_color>
                        <thumb_hilite_color>0xFFCCCCCC</thumb_hilite_color>
                        <arrow_buttons size="0"/>
                    </scrollbars>
                </scrolling>
            </menu>
            <arrow_buttons align="right" size="10">
                <chevron_size>4</chevron_size>
                <fg_color>0xFFD0D0D0</fg_color>
                <bg_color>0x00FFFFFF</bg_color>
                <border_color>0xFFB3B3B3</border_color>
                <border_thickness>0</border_thickness>
            </arrow_buttons>
        </text_menu_widget>
        <toggle_widget height="16" id="sync" left="0" name="Sync" top="0" width="16">
            <anchor_pos right="0" top="5"/>
            <visible>no</visible>
            <bg_color>0x00000000</bg_color>
            <image>49</image>
            <icon_placement spacing="4">-1</icon_placement>
            <text>
                <font name="Helvetica" size="12"/>
            </text>
        </toggle_widget>
        <toggle_widget height="20" id="midl" left="0" name="MIDI Learn" top="0" width="16">
            <anchor_pos right="4" top="4"/>
            <visible>no</visible>
            <bg_color>0x00000000</bg_color>
            <image>85</image>
            <icon_placement spacing="4">-1</icon_placement>
            <text>
                <font name="Helvetica" size="12"/>
            </text>
        </toggle_widget>
    </panel_widget>
</xg>