
<xg>
    <panel_widget height="210" id="main" left="0" top="0" width="480">
        <bg_color>0xFF1D1D1D</bg_color>
        <border_color>0xFFB3B3B3</border_color>
        <pushbutton_widget height="25" id="canc" left="0" top="0" width="80">
            <anchor_pos bottom="16" left="140"/>
            <bg_color>0xFF393939</bg_color>
            <corner_radius>3</corner_radius>
            <text>
                <label>CANCEL</label>
                <font name="Roboto" size="12"/>
                <text_color>0xFFEDEDED</text_color>
            </text>
            <active_state>
                <bg_color>0xFF595B5C</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF696C6E</bg_color>
            </hilite_state>
        </pushbutton_widget>
        <pushbutton_widget height="25" id="okay" left="0" top="0" width="80">
            <anchor_pos bottom="16" left="260"/>
            <bg_color>0xFF393939</bg_color>
            <corner_radius>3</corner_radius>
            <text>
                <label>OK</label>
                <font name="Roboto" size="12"/>
                <text_color>0xFFEDEDED</text_color>
            </text>
            <active_state>
                <bg_color>0xFF595B5C</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF696C6E</bg_color>
            </hilite_state>
        </pushbutton_widget>
        <text_widget height="32" id="titl" left="0" name="main label" top="0" width="160">
            <anchor_pos top="20"/>
            <relative_pos x="50"/>
            <text>
                <label>Import Favorites</label>
                <font name="Roboto" size="14" style="bold"/>
                <align horz="center" vert="middle"/>
                <multiline>yes</multiline>
                <text_color>0xFFD0D0D0</text_color>
            </text>
        </text_widget>
        <radio_widget height="72" id="rdio" left="0" top="0" width="25">
            <anchor_pos left="20" top="65"/>
            <radio_button_widget height="0" id="1" left="3" top="3" width="0">
                <bg_color>0xFF333333</bg_color>
                <image>76</image>
                <border_color>0xFFCCCCCC</border_color>
                <corner_radius>2</corner_radius>
                <active_state>
                    <bg_color>0xFF666666</bg_color>
                </active_state>
                <hilite_state>
                    <bg_color>0xFFCCCCCC</bg_color>
                </hilite_state>
            </radio_button_widget>
            <radio_button_widget height="0" id="2" left="3" top="47" width="0">
                <bg_color>0xFF333333</bg_color>
                <image>76</image>
                <border_color>0xFFCCCCCC</border_color>
                <border_thickness>0</border_thickness>
                <corner_radius>2</corner_radius>
                <active_state>
                    <bg_color>0xFF666666</bg_color>
                </active_state>
                <hilite_state>
                    <bg_color>0xFFCCCCCC</bg_color>
                </hilite_state>
            </radio_button_widget>
        </radio_widget>
        <text_widget height="18" id="opt1" left="0" top="0" width="1">
            <anchor_pos left="50" right="20" top="67"/>
            <text>
                <label>Insert new favorite(s) before the highlighted favorite.</label>
                <font name="Roboto" size="12"/>
                <align vert="middle"/>
                <multiline>yes</multiline>
                <text_color>0xFFB1B1B1</text_color>
            </text>
        </text_widget>
        <text_widget height="18" id="opt2" left="0" top="0" width="1">
            <anchor_pos left="50" right="20" top="112"/>
            <text>
                <label>Replace all existing favorite(s) starting from the highlighted favorite.</label>
                <font name="Roboto" size="12"/>
                <align vert="middle"/>
                <multiline>yes</multiline>
                <text_color>0xFFB1B1B1</text_color>
            </text>
        </text_widget>
    </panel_widget>
</xg>