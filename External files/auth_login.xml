<xg>
	<panel_widget height="280" id="1" left="0" top="0" width="320">
		<relative_pos x="50" y="50"/>

		<!-- Login message -->
		<text_widget height="60" id="msg-">
			<anchor_pos left="10" right="10" top="10"/>
			<text>
				<label>Please sign in to your Line 6 account:</label>
				<font name="Roboto" size="14"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFFB3B3B3</text_color>
				<multiline>yes</multiline>
			</text>
		</text_widget>
		
		<!-- Activity spinner -->
		<image_widget height="25" id="dnax" left="0" name="DNA Animation" top="0" width="70">
			<anchor_pos top="50"/>
			<relative_pos x="50"/>
			<image>8</image>
		</image_widget>
		
		<!-- User name -->
		<text_edit_widget height="30" id="lnam" left="0" top="80" width="1">
			<anchor_pos left="75" right="75"/>
			<bg_color>0xFF000000</bg_color>
			<focus_color>0xFF87FF80</focus_color>
			<border_color>0xFFB3B3B3</border_color>
			<text>
				<font name="Roboto" size="15"/>
				<align horz="left" vert="middle"/>
				<offset x="8" y="0"/>
				<text_color>0xFFB3B3B3</text_color>
			</text>
			<activate_on_focus>yes</activate_on_focus>
		</text_edit_widget>

		<!-- Password -->
		<text_edit_widget height="30" id="lpwd" left="0" top="120" width="1">
			<anchor_pos left="75" right="75"/>
			<bg_color>0xFF000000</bg_color>
			<focus_color>0xFF87FF80</focus_color>
			<border_color>0xFFB3B3B3</border_color>
			<text>
				<font name="Roboto" size="15"/>
				<align horz="left" vert="middle"/>
				<offset x="8" y="0"/>
				<text_color>0xFFB3B3B3</text_color>
			</text>
			<secure>yes</secure>
			<activate_on_focus>yes</activate_on_focus>
		</text_edit_widget>

		<!-- Login btn -->
		<pushbutton_widget height="29" id="lgin" left="0" top="160" width="80">
			<relative_pos x="50"/>
			<bg_color>0xFF000000</bg_color>
			<focus_color>0xFF87FF80</focus_color>
			<border_color>0xFF336D87</border_color>
			<text>
				<label>Sign In</label>
				<font name="Roboto" size="14"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFFB3B3B3</text_color>
			</text>
			<button_repeat>no</button_repeat>
			<active_state>
				<bg_color>0xFF081D24</bg_color>
				<fg_color>0xFF3E84A3</fg_color>
			</active_state>
			<hilite_state>
				<bg_color>0xFF122F3A</bg_color>
			</hilite_state>
		</pushbutton_widget>

		<!-- Forgot credentials btn -->
		<pushbutton_widget height="20" id="lfgt" left="0" top="205" width="1">
			<anchor_pos left="10" right="10"/>
			<bg_color>0x00000000</bg_color>
			<focus_color>0x00000000</focus_color>
			<border_color>0x00000000</border_color>
			<text>
				<label>Forgot password/username?</label>
				<font name="Roboto" size="14"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFF336D87</text_color>
			</text>
			<button_repeat>no</button_repeat>
			<active_state>
				<bg_color>0x00000000</bg_color>
				<fg_color>0x88336D87</fg_color>
			</active_state>
			<hilite_state>
				<fg_color>0xFF3E84A3</fg_color>
			</hilite_state>
		</pushbutton_widget>

		<!-- Create account btn -->
		<pushbutton_widget height="20" id="lcrt" left="0" top="235" width="1">
			<anchor_pos left="10" right="10"/>
			<bg_color>0x00000000</bg_color>
			<focus_color>0x00000000</focus_color>
			<border_color>0x00000000</border_color>
			<text>
				<label>Create a Line 6 Account</label>
				<font name="Roboto" size="14"/>
				<align horz="center" vert="middle"/>
				<text_color>0xFF336D87</text_color>
			</text>
			<button_repeat>no</button_repeat>
			<active_state>
				<bg_color>0x00000000</bg_color>
				<fg_color>0x88336D87</fg_color>
			</active_state>
			<hilite_state>
				<fg_color>0xFF3E84A3</fg_color>
			</hilite_state>
		</pushbutton_widget>
	</panel_widget>
</xg>
