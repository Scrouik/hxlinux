
<xg>
    <panel_widget height="450" id="updw" left="0" top="0" width="800">
        <anchor_pos bottom="0" left="0" right="0" top="0"/>
        <bg_color>0xB0000000</bg_color>
        <disabled_color>0xB0000000</disabled_color>
        <panel_widget height="110" id="updw" left="0" top="0" width="100">
            <anchor_pos left="30" right="30" top="0"/>
            <image_widget id="hxlo" left="0" top="0" height="110" width="330" name="Helix Logo">
                <relative_pos x="50" y="50"/>
                <image>60</image>
                <scale_mode>keep_aspect</scale_mode>
            </image_widget>
            <image_widget id="l6lo" left="0" top="0" height="110" width="160" name="Line 6 Logo">
                <anchor_pos bottom="0" left="0" top="0"/>
                <relative_pos x="0" x_align="left" y="50"/>
                <image>15</image>
                <scale_mode>keep_aspect</scale_mode>
            </image_widget>
            <image_widget id="dvil" left="0" top="0" width="200" name="Device About Image">
                <anchor_pos bottom="0" right="0" top="0"/>
                <relative_pos x_align="right" x="100" y="50"/>
                <image>89</image>
                <scale_mode>keep_aspect</scale_mode>
            </image_widget>
        </panel_widget>
        <panel_widget height="1000" id="webv" left="1" top="1" width="1034">
            <anchor_pos bottom="60" left="30" right="30" top="110"/>
            <bg_color>0xFF1D1D1D</bg_color>
            <border_color>0xFF393939</border_color>
            <border_thickness>2</border_thickness>
            <corner_radius>3</corner_radius>
        </panel_widget>
        <text_widget height="30" id="stal" left="1" top="1" width="250">
            <anchor_pos bottom="28"/>
            <relative_pos width="50" x="50"/>
            <bg_color>0xB0000000</bg_color>
            <text>
                <label></label>
                <font name="Roboto" size="14"/>
                <align horz="center" vert="middle"/>
                <multiline>yes</multiline>
                <text_color>0xFFD0D0D0</text_color>
            </text>
        </text_widget>
        <image_widget height="16" id="upsp" left="0" name="Activity Spinner" top="0" width="16">
            <anchor_pos bottom="10"/>
            <relative_pos x="50"/>
            <visible>no</visible>
        </image_widget>
        <statusbar_widget height="16" id="upba" left="0" name="Progress Bar" top="0" width="160">
            <anchor_pos bottom="10"/>
            <relative_pos x="50"/>
            <visible>no</visible>
            <bg_color>0xFF393939</bg_color>
            <fill_area height="0" left="0" top="0" width="0"/>
            <fill_color>0xFF87FF80</fill_color>
        </statusbar_widget>
        <pushbutton_widget height="29" id="uvbb" left="100" name="Back Button" top="0" width="160">
            <anchor_pos bottom="10" left="30"/>
            <bg_color>0xFF393939</bg_color>
            <border_color>0xFF393939</border_color>
            <border_thickness>2</border_thickness>
            <corner_radius>3</corner_radius>
            <disabled_opacity>91</disabled_opacity>
            <text>
                <label>Back to HX Edit</label>
                <font name="Roboto" size="15"/>
                <text_color>0xFFD0D0D0</text_color>
            </text>
            <active_state>
                <bg_color>0xFF393939</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF474747</bg_color>
            </hilite_state>
        </pushbutton_widget>
        <pushbutton_widget height="29" id="uvnb" left="0" name="Next Button" top="0" width="160">
            <relative_pos x_align="right"/>
            <anchor_pos bottom="10" right="30"/>
            <bg_color>0xFF393939</bg_color>
            <border_color>0xFF393939</border_color>
            <border_thickness>2</border_thickness>
            <corner_radius>3</corner_radius>
            <disabled_opacity>91</disabled_opacity>
            <text>
                <label>Next</label>
                <font name="Roboto" size="15"/>
                <text_color>0xFFD0D0D0</text_color>
            </text>
            <active_state>
                <bg_color>0xFF393939</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF474747</bg_color>
            </hilite_state>
        </pushbutton_widget>
        <pushbutton_widget height="29" id="urnb" left="0" name="Release Notes Button" top="0" width="160">
            <anchor_pos bottom="10"/>
            <relative_pos x="50"/>
            <visible>no</visible>
            <bg_color>0xFF393939</bg_color>
            <border_color>0xFF393939</border_color>
            <border_thickness>2</border_thickness>
            <corner_radius>3</corner_radius>
            <disabled_opacity>91</disabled_opacity>
            <text>
                <label>Release Notes...</label>
                <font name="Roboto" size="15"/>
                <text_color>0xFFD0D0D0</text_color>
            </text>
            <active_state>
                <bg_color>0xFF393939</bg_color>
            </active_state>
            <hilite_state>
                <bg_color>0xFF474747</bg_color>
            </hilite_state>
        </pushbutton_widget>
    </panel_widget>
</xg>
